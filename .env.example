# Calibre Web 配置文件

# Calibre书库路径（指向您的Calibre书库目录，包含metadata.db文件的目录）
# 例如 Windows: D:\My Calibre Library
# 例如 Linux/Mac: /home/user/Calibre Library
CALIBRE_LIBRARY_PATH=

# 是否启用Calibre数据库自动导入（启动时自动从Calibre导入书籍）
USE_CALIBRE_DB=False

# Flask密钥（生产环境请修改为随机字符串）
SECRET_KEY=your-secret-key-change-in-production

# 服务器配置
PORT=5000
HOST=0.0.0.0
DEBUG=True

# AI辅助功能配置
# Ollama API配置
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:latest
OLLAMA_TIMEOUT=60

# SearXNG配置（用于AI搜索网络信息）
SEARXNG_BASE_URL=http://localhost:8080
SEARXNG_ENABLED=True
